{
    "$schema": "https://schema.tauri.app/2.0.0/tauri.schema.json",
    "productName": "Wonka",
    "version": "0.1.4",
    "identifier": "com.wonka.pos",
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "build": {
        "beforeDevCommand": "bun dev",
        "beforeBuildCommand": "bun run build",
        "devUrl": "https://wonka-fronted-production.up.railway.app",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Wonka",
                "width": 800,
                "height": 600
            }
        ],
        "security": {
            "csp": null
        }
    }
}