{
    "$schema": "https://schema.tauri.app/2.0.0/tauri.schema.json",
    "productName": "Wonka",
    "version": "0.1.0",
    "identifier": "com.wonka.pos",
    "bundle": {
        "active": true,
        "targets": "all"
    },
    "build": {
        "beforeDevCommand": "bun dev",
        "beforeBuildCommand": "bun run build",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Wonka",
                "width": 800,
                "height": 600
            }
        ],
        "security": {
            "csp": null
        }
    }
}