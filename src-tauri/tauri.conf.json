{
    "$schema": "https://schema.tauri.app/2.0.0/tauri.schema.json",
    "productName": "Wonka",
    "version": "0.1.4",
    "identifier": "com.wonka.app",
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "build": {
        "beforeDevCommand": "bun run dev",
        "beforeBuildCommand": "bun run build",
        "devUrl": "https://wonka-fronted-production.up.railway.app",
        "frontendDist": "https://wonka-fronted-production.up.railway.app"
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://wonka-backend-production.up.railway.app/public/updater/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc4QzU2MzJCRDI3MkQ4RDIKUldUUzJITFNLMlBGZUhjSllaS3F6YkR0RExQOEpvSWJUSm92b1NEYnlySUVUUitLTjhLTGJRakYK",
            "windows": {
                "installMode": "passive"
            }
        }
    },
    "app": {
        "windows": [
            {
                "title": "Wonka Updater",
                "label": "splashscreen",
                "width": 320,
                "height": 400,
                "resizable": false,
                "decorations": false,
                "alwaysOnTop": true,
                "center": true,
                "transparent": true,
                "url": "/splash"
            },
            {
                "title": "Wonka",
                "label": "main",
                "width": 1200,
                "height": 800,
                "center": true,
                "visible": false,
                "url": "/"
            }
        ],
        "security": {
            "csp": null
        }
    }
}